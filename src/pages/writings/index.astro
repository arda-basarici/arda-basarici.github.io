---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { showWritings } from '../../data/site';

// Section gated by the same flag as the nav link.
if (!showWritings) return Astro.redirect('/');

const writings = (await getCollection('writings', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Writings — Arda Başarıcı" description="Essays and articles by Arda Başarıcı.">
  <h1>Writings</h1>

  {writings.length === 0 && <p class="empty">Nothing here yet — first piece coming soon.</p>}

  <ul class="list">
    {
      writings.map((a) => (
        <li>
          <a href={`/writings/${a.id}/`}>{a.data.title}</a>
          <time datetime={a.data.date.toISOString()}>{formatDate(a.data.date)}</time>
          <p>{a.data.description}</p>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .empty {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
  }
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .list li {
    margin-bottom: 26px;
    border-top: 1px solid var(--hair);
    padding-top: 16px;
  }
  .list a {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 22px;
    color: var(--bright);
    text-decoration: none;
    transition: color 0.15s;
  }
  /* content clickables carry a marker: → deeper in-site (see Base.astro) */
  .list a::after {
    content: ' →';
    color: var(--blue);
    font-size: 0.7em;
  }
  .list a:hover {
    color: var(--amber);
  }
  time {
    display: block;
    font-size: 13px;
    color: var(--muted);
    margin: 3px 0 5px;
  }
  .list p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    max-width: 60ch;
  }
</style>
