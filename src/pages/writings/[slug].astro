---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { showWritings } from '../../data/site';

export async function getStaticPaths() {
  // Section gated by the same flag as the nav link.
  if (!showWritings) return [];
  const writings = await getCollection('writings', ({ data }) => !data.draft);
  return writings.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${article.data.title} — Arda Başarıcı`} description={article.data.description}>
  <article>
    <h1>{article.data.title}</h1>
    <p class="meta">
      <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
      {
        article.data.updated && (
          <span>
            · updated{' '}
            <time datetime={article.data.updated.toISOString()}>
              {formatDate(article.data.updated)}
            </time>
          </span>
        )
      }
    </p>
    <div class="body">
      <Content />
    </div>
  </article>
</Base>

<style>
  h1 {
    margin-bottom: 8px;
  }
  .meta {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    font-size: 15px;
    margin: 0 0 26px;
  }
  .body {
    font-size: 16px;
  }
  .body :global(p),
  .body :global(li) {
    max-width: 64ch;
  }
  .body :global(h2) {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 24px;
    color: var(--bright);
    margin: 30px 0 10px;
  }
  .body :global(a) {
    color: var(--amber);
  }
  .body :global(pre) {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    overflow-x: auto;
    font-size: 14px;
  }
  .body :global(code) {
    font-size: 0.95em;
  }
  .body :global(:not(pre) > code) {
    background: var(--card);
    border: 1px solid var(--hair);
    border-radius: 4px;
    padding: 1px 5px;
  }
  .body :global(blockquote) {
    border-left: 3px solid var(--amber-deep);
    margin: 16px 0;
    padding: 2px 0 2px 16px;
    color: var(--muted);
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
  }
</style>
