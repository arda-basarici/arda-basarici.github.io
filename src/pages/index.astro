---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { featured } from '../data/featured';
import { seriesInfo } from '../data/series';

type Project = CollectionEntry<'projects'>;

const all = await getCollection('projects', ({ data }) => !data.draft);
const byId = new Map(all.map((p) => [p.id, p]));

const featuredBlocks = featured.map((entry) => {
  if (entry.kind === 'series') {
    const members = all
      .filter((p) => p.data.series === entry.id)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
    // The card shows the arc's culmination: the last member that has a figure.
    const figureBearer = [...members].reverse().find((p) => p.data.figure);
    return { kind: 'series' as const, id: entry.id, info: seriesInfo[entry.id], members, figureBearer };
  }
  return { kind: 'project' as const, id: entry.id, project: byId.get(entry.id) as Project };
});
---

<Base
  title="Arda Başarıcı — AI/ML Engineering"
  description="Mathematics → game development → Data, ML, and AI. A bias for honest evaluation over shiny demos."
>
  <header>
    <h1>Arda Başarıcı</h1>
    <p class="tag">Mathematics → 3 yrs game dev → Data, ML &amp; AI engineering.</p>
    <p class="tax">
      I like understanding the structure underneath an answer — what it assumes, and whether the
      evidence actually supports it. A bias for honest evaluation over shiny demos; building a
      portfolio in public.
    </p>
    <div class="links">
      <a href="https://github.com/arda-basarici">GitHub</a>
      <a href="https://www.linkedin.com/in/ardabasarici">LinkedIn</a>
      <a href="/about/">More about me →</a>
    </div>
  </header>

  <hr />

  <h2>Featured work</h2>

  {
    featuredBlocks.map((block) =>
      block.kind === 'series' ? (
        <div class="card">
          <h3>{block.info?.title ?? block.id}</h3>
          {block.info && <p>{block.info.blurb}</p>}
          {block.figureBearer?.data.figure && (
            <a class="figure" href={`/projects/${block.figureBearer.id}/`}>
              <Image
                src={block.figureBearer.data.figure}
                alt={block.figureBearer.data.figureAlt ?? block.figureBearer.data.title}
                width={660}
                densities={[1.5, 2]}
                quality={90}
              />
            </a>
          )}
          <ol class="parts">
            {block.members.map((p) => (
              <li>
                <a href={`/projects/${p.id}/`}>{p.data.title}</a>
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <div class="card">
          <h3>
            <a href={`/projects/${block.project.id}/`}>{block.project.data.title}</a>
          </h3>
          <p>{block.project.data.summary}</p>
          {block.project.data.figure && (
            <a class="figure" href={`/projects/${block.project.id}/`}>
              <Image
                src={block.project.data.figure}
                alt={block.project.data.figureAlt ?? block.project.data.title}
                width={660}
                densities={[1.5, 2]}
                quality={90}
              />
            </a>
          )}
          <div class="row">
            {block.project.data.links.report && (
              <a href={block.project.data.links.report}>Report (PDF)</a>
            )}
            {block.project.data.links.code && <a href={block.project.data.links.code}>Code</a>}
          </div>
        </div>
      )
    )
  }

  <p class="all">
    <a href="/projects/">All projects →</a>
  </p>

  <footer>
    <p>
      This site is the stable front door: published posts and report PDFs link here, not at deep
      repo paths, so links keep working when repositories move.
    </p>
  </footer>
</Base>

<style>
  h1 {
    font-size: 30px;
    line-height: 1.2;
    margin: 0 0 8px;
  }
  .tag {
    font-size: 17px;
    color: var(--muted);
    margin: 0 0 4px;
  }
  .tax {
    font-size: 15px;
    color: var(--muted);
    margin: 0;
  }
  .links {
    margin: 18px 0 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .links a {
    text-decoration: none;
    color: var(--accent);
    border: 1px solid var(--line);
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 14px;
    background: #fff;
  }
  .links a:hover {
    border-color: var(--accent);
  }
  hr {
    border: none;
    border-top: 1px solid var(--line);
    margin: 34px 0;
  }
  h2 {
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 18px;
  }
  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 16px;
  }
  .card h3 {
    margin: 0 0 6px;
    font-size: 18px;
  }
  .card h3 a {
    color: var(--ink);
    text-decoration: none;
  }
  .card h3 a:hover {
    color: var(--accent);
  }
  .card p {
    margin: 0 0 12px;
    color: var(--muted);
    font-size: 15px;
  }
  .figure {
    display: block;
    margin: 0 0 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    padding: 6px;
  }
  .figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
  }
  .parts {
    margin: 0;
    padding-left: 22px;
    font-size: 15px;
  }
  .parts li {
    margin-bottom: 3px;
  }
  .parts a {
    color: var(--accent);
    text-decoration: none;
  }
  .parts a:hover {
    text-decoration: underline;
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .row a {
    text-decoration: none;
    font-size: 13.5px;
    color: var(--accent);
    border: 1px solid var(--line);
    padding: 4px 11px;
    border-radius: 16px;
  }
  .row a:hover {
    border-color: var(--accent);
  }
  .all {
    margin: 8px 0 0;
  }
  .all a {
    color: var(--accent);
    text-decoration: none;
    font-size: 15px;
  }
  footer {
    margin-top: 40px;
    font-size: 13px;
    color: #9aa2b1;
  }
</style>
