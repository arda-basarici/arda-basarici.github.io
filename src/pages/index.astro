---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { featured } from '../data/featured';
import portrait from '../assets/portrait.jpeg';

const all = await getCollection('projects', ({ data }) => !data.draft);
const byId = new Map(all.map((p) => [p.id, p]));
const seriesById = new Map(
  (await getCollection('series', ({ data }) => !data.draft)).map((s) => [s.id, s])
);

const featuredBlocks = featured.map((entry) => {
  if (entry.kind === 'series') {
    const info = seriesById.get(entry.id);
    if (!info) {
      throw new Error(
        `src/data/featured.ts references unknown or draft series id "${entry.id}" — ` +
          `expected one of: ${[...seriesById.keys()].join(', ')}`
      );
    }
    const members = all
      .filter((p) => p.data.series === entry.id)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
    return { kind: 'series' as const, id: entry.id, info, members };
  }
  const project = byId.get(entry.id);
  if (!project) {
    throw new Error(
      `src/data/featured.ts references unknown or draft project id "${entry.id}" — ` +
        `expected one of: ${[...byId.keys()].join(', ')}`
    );
  }
  return { kind: 'project' as const, id: entry.id, project };
});
---

<Base
  title="Arda Başarıcı — AI/ML Engineering"
  description="Mathematics → game development → Data, ML, and AI. A bias for honest evaluation over shiny demos."
>
  <header>
    <div class="hero">
      <div class="hero-text">
        <h1>Evidence,<br />honestly weighed.</h1>
        <p class="tagline">Mathematics → game development → data, ML &amp; AI.</p>
        <p class="intro">
          I like understanding the structure underneath an answer — what it assumes, and whether
          the evidence actually supports it. A bias for honest evaluation over shiny demos;
          building a portfolio in public.
        </p>
        <div class="links">
          <a class="qlink" href="https://github.com/arda-basarici">GitHub</a>
          <a class="qlink" href="https://www.linkedin.com/in/ardabasarici">LinkedIn</a>
        </div>
      </div>
      <div class="portrait">
        <Image src={portrait} alt="Arda Başarıcı" width={210} densities={[1.5, 2]} quality={85} />
      </div>
    </div>
  </header>

  <div class="rule"><h2>Featured work</h2></div>

  {
    featuredBlocks.map((block) =>
      block.kind === 'series' ? (
        <div class="card">
          <h3>
            <a href={`/projects/${block.id}/`}>{block.info.data.title}</a>
          </h3>
          <p class="desc">{block.info.data.blurb}</p>
          <ol class="ledger">
            {block.members.map((p) => (
              <li>
                <a href={`/projects/${p.id}/`}>
                  <span class="lrow">
                    <span class="t">{p.data.title}</span>
                    {p.data.seriesRole && <small>{p.data.seriesRole}</small>}
                  </span>
                  {p.data.seriesNote && <span class="note">{p.data.seriesNote}</span>}
                </a>
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <div class="card">
          <h3>
            <a href={`/projects/${block.project.id}/`}>{block.project.data.title}</a>
          </h3>
          <p class="desc">{block.project.data.summary}</p>
          <div class="refs">
            {block.project.data.links.report && (
              <a class="qlink" href={block.project.data.links.report}>
                Report (PDF)
              </a>
            )}
            {block.project.data.links.code && (
              <a class="qlink" href={block.project.data.links.code}>
                Code
              </a>
            )}
            {block.project.data.links.demo && (
              <a class="qlink" href={block.project.data.links.demo}>
                Live demo
              </a>
            )}
          </div>
        </div>
      )
    )
  }

  <p class="more">
    <a class="qlink fwd" href="/projects/">All projects</a>
  </p>
</Base>

<style>
  .hero {
    display: flex;
    gap: 36px;
    align-items: flex-start;
  }
  .hero-text {
    flex: 1;
  }
  .portrait {
    flex: 0 0 210px;
    height: 210px;
    border-radius: 50%;
    margin-top: 8px;
    border: 2px solid var(--border);
    box-shadow: 6px 6px 0 var(--shadow);
    overflow: hidden;
  }
  .portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 26%;
    display: block;
  }
  @media (max-width: 640px) {
    .hero {
      flex-direction: column-reverse;
    }
    .portrait {
      flex: 0 0 auto;
      width: 140px;
      height: 140px;
    }
  }

  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 52px;
    line-height: 1.06;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
    color: var(--bright);
  }
  .tagline {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--amber);
    margin: 0 0 16px;
  }
  .intro {
    font-size: 16.5px;
    color: var(--muted);
    max-width: 56ch;
    margin: 0 0 22px;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
    font-size: 14.5px;
  }
  .more {
    font-size: 15.5px;
    margin-top: 4px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 40px;
    }
  }
</style>
