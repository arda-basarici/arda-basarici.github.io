---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { seriesInfo } from '../../data/series';

type Project = CollectionEntry<'projects'>;

const all = await getCollection('projects', ({ data }) => !data.draft);

const bySeries = new Map<string, Project[]>();
const standalone: Project[] = [];
for (const project of all) {
  const id = project.data.series;
  if (id) {
    bySeries.set(id, [...(bySeries.get(id) ?? []), project]);
  } else {
    standalone.push(project);
  }
}
for (const members of bySeries.values()) {
  members.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
}
---

<Base title="Projects — Arda Başarıcı" description="AI/ML projects by Arda Başarıcı.">
  <h1>Projects</h1>

  {
    [...bySeries.entries()].map(([id, members]) => {
      const info = seriesInfo[id];
      return (
        <div class="card">
          <h3>{info?.title ?? id}</h3>
          {info && <p class="desc">{info.blurb}</p>}
          <ol class="ledger">
            {members.map((p) => (
              <li>
                <a href={`/projects/${p.id}/`}>
                  <span class="lrow">
                    <span class="t">{p.data.title}</span>
                    {p.data.seriesRole && <small>{p.data.seriesRole}</small>}
                  </span>
                  {p.data.seriesNote && <span class="note">{p.data.seriesNote}</span>}
                </a>
              </li>
            ))}
          </ol>
        </div>
      );
    })
  }

  <div class="rule"><h2>Standalone</h2></div>

  {
    standalone.map((p) => (
      <div class="card">
        <h3>
          <a href={`/projects/${p.id}/`}>{p.data.title}</a>
        </h3>
        <p class="desc">{p.data.summary}</p>
        <div class="refs">
          {p.data.links.report && (
            <a class="qlink" href={p.data.links.report}>
              Report (PDF)
            </a>
          )}
          {p.data.links.code && (
            <a class="qlink" href={p.data.links.code}>
              Code
            </a>
          )}
          {p.data.links.demo && (
            <a class="qlink" href={p.data.links.demo}>
              Live demo
            </a>
          )}
        </div>
      </div>
    ))
  }
</Base>
