---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { seriesInfo } from '../../data/series';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const arc = project.data.series
  ? (
      await getCollection(
        'projects',
        ({ data }) => !data.draft && data.series === project.data.series
      )
    ).sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];
---

<Base title={`${project.data.title} — Arda Başarıcı`} description={project.data.summary}>
  <article>
    <h1>{project.data.title}</h1>
    {project.data.demonstrates && <p class="demonstrates">{project.data.demonstrates}</p>}
    <div class="refs">
      {
        project.data.links.report && (
          <a class="qlink" href={project.data.links.report}>
            Report (PDF)
          </a>
        )
      }
      {
        project.data.links.code && (
          <a class="qlink" href={project.data.links.code}>
            Code
          </a>
        )
      }
      {
        project.data.links.demo && (
          <a class="qlink" href={project.data.links.demo}>
            Live demo
          </a>
        )
      }
    </div>
    <div class="body">
      <Content />
    </div>
  </article>

  {
    arc.length > 1 && (
      <aside class="arc-nav">
        <div class="rule">
          <h2>{seriesInfo[project.data.series!]?.title ?? project.data.series} — the full arc</h2>
        </div>
        <ol class="ledger">
          {arc.map((p) => (
            <li>
              {p.id === project.id ? (
                <span aria-current="page" class="current">
                  <span class="lrow">
                    <span class="t">{p.data.title}</span>
                    {p.data.seriesRole && <small>{p.data.seriesRole}</small>}
                  </span>
                </span>
              ) : (
                <a href={`/projects/${p.id}/`}>
                  <span class="lrow">
                    <span class="t">{p.data.title}</span>
                    {p.data.seriesRole && <small>{p.data.seriesRole}</small>}
                  </span>
                </a>
              )}
            </li>
          ))}
        </ol>
      </aside>
    )
  }
</Base>

<style>
  h1 {
    margin-bottom: 10px;
  }
  .demonstrates {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--amber);
    margin: 0 0 16px;
  }
  .refs {
    margin-bottom: 26px;
  }
  .body {
    font-size: 16px;
  }
  .body :global(p),
  .body :global(li) {
    max-width: 64ch;
  }
  .body :global(h2) {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 23px;
    color: var(--bright);
    margin: 30px 0 10px;
  }
  .body :global(ul) {
    padding-left: 22px;
  }
  .body :global(strong) {
    color: var(--bright);
    font-weight: 600;
  }
  .body :global(a) {
    color: var(--amber);
  }
  .body :global(code) {
    background: var(--card);
    border: 1px solid var(--hair);
    border-radius: 4px;
    padding: 1px 5px;
    font-size: 0.9em;
  }
  .arc-nav {
    margin-top: 24px;
  }
</style>
